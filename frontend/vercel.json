{
  "version": 2,
  "name": "academico-frontend",
  "buildCommand": null,
  "outputDirectory": ".",
  "rewrites": [
    { "source": "/",            "destination": "/pages/login.html" },
    { "source": "/login",       "destination": "/pages/login.html" },
    { "source": "/dashboard",   "destination": "/pages/dashboard.html" },
    { "source": "/students",    "destination": "/pages/students.html" },
    { "source": "/trainers",    "destination": "/pages/trainers.html" },
    { "source": "/courses",     "destination": "/pages/courses.html" },
    { "source": "/classes",     "destination": "/pages/classes.html" },
    { "source": "/grades",      "destination": "/pages/grades.html" }
  ],
  "headers": [
    {
      "source": "/js/(.*)\\.js",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" },
        { "key": "Content-Type",  "value": "text/javascript; charset=utf-8" }
      ]
    },
    {
      "source": "/css/(.*)\\.css",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" },
        { "key": "Content-Type",  "value": "text/css; charset=utf-8" }
      ]
    },
    {
      "source": "/(.*)\\.html",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=0, must-revalidate" },
        { "key": "X-Frame-Options", "value": "DENY" },
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "Referrer-Policy", "value": "strict-origin-when-cross-origin" },
        { "key": "X-Robots-Tag", "value": "noindex, nofollow" },
        { "key": "Content-Security-Policy", "value": "default-src 'self'; script-src 'self'; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; font-src https://fonts.gstatic.com; connect-src 'self' https://matrika-production.up.railway.app; img-src 'self' data:; frame-ancestors 'none'" }
      ]
    }
  ]
}
