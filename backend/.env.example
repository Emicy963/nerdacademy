# ── Django ────────────────────────────────────────────────────────────────────
DJANGO_SETTINGS_MODULE=core.settings.development
SECRET_KEY=your-very-secret-key-here-change-in-production
DEBUG=True

# ── Database (local development) ──────────────────────────────────────────────
DB_NAME=academico_db
DB_USER=academico_user
DB_PASSWORD=strongpassword
DB_HOST=localhost
DB_PORT=5432

# ── Database (Railway — replaces the individual vars above in production) ──────
# DATABASE_URL=postgresql://user:password@host:port/dbname

# ── JWT ───────────────────────────────────────────────────────────────────────
JWT_ACCESS_TOKEN_MINUTES=60
JWT_REFRESH_TOKEN_DAYS=7

# ── Email (Gmail SMTP) ────────────────────────────────────────────────────────
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
DEFAULT_FROM_EMAIL=Académico <noreply@yourdomain.ao>
EMAIL_HOST_USER=your-gmail@gmail.com
EMAIL_HOST_PASSWORD=your-app-password

# ── Frontend URL (used in password-reset links) ───────────────────────────────
FRONTEND_URL=http://127.0.0.1:3000

# ── Production only ───────────────────────────────────────────────────────────
# ALLOWED_HOSTS=your-app.up.railway.app,yourdomain.ao
# CORS_ALLOWED_ORIGINS=https://your-frontend.vercel.app,https://yourdomain.ao
# FRONTEND_URL=https://your-frontend.vercel.app
